{
  "expo": {
    "name": "Stash",
    "slug": "stash-mobile",
    "version": "1.0.0",
    "scheme": "stash",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "bundleIdentifier": "com.mattssoftware.stash.mobile",
      "supportsTablet": true,
      "usesAppleSignIn": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
